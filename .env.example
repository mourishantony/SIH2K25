# Copy this file to .env and tweak the values as needed.
# Each setting mirrors a CLI option; flags still override the values below.

## Registration CLI equivalents
# FACE_REG_TOTAL_SAMPLES == --total-samples (single continuous session)
FACE_REG_TOTAL_SAMPLES=50
# FACE_REG_MIN_CONFIDENCE == --min-confidence
FACE_REG_MIN_CONFIDENCE=0.35
# FACE_REG_CAMERA_INDEX == --camera-index
FACE_REG_CAMERA_INDEX=0
# FACE_REG_USE_GPU == --use-gpu
FACE_REG_USE_GPU=false

## Person Re-ID + Tracking (used by monitor_contacts.py)
# FACE_REID_DET_CONF == YOLO person detection confidence threshold
FACE_REID_DET_CONF=0.35
# FACE_REID_DETECTOR == YOLO weights path
FACE_REID_DETECTOR=yolov8n.pt
# FACE_REID_EMBEDDER_GPU == use GPU for OSNet features
FACE_REID_EMBEDDER_GPU=false
# FACE_REID_NMS_IOU == NMS IoU threshold for YOLO person detections
FACE_REID_NMS_IOU=0.35
# FACE_REID_BOX_SHRINK == fraction to trim from YOLO boxes before DeepSORT (0.0-0.4 recommended)
FACE_REID_BOX_SHRINK=0.1

## Dual-camera monitoring (front = laptop cam, side = external cam by default)
FRONT_CAMERA_INDEX=0
FRONT_VIDEO_PATH=
FRONT_VIDEO_PROMPT=false
SIDE_CAMERA_INDEX=1
SIDE_VIDEO_PATH=
SIDE_VIDEO_PROMPT=false

## Contact tracing/risk accumulation
CONTACT_BASE_RATE=0.02
CONTACT_EVENT_PENALTY=0.05
CONTACT_MASK_EFFECT=0.5
CONTACT_MASK_DECAY_SECONDS=8.0
CONTACT_OVERLAP_THRESHOLD=0.18
CONTACT_LOG_DIR=Contact_Details
CONTACT_SYNC_WINDOW=0.5

## Collision risk + alerting
COLLISION_IOU_THRESHOLD=0.1
COLLISION_DISTANCE_THRESHOLD=200
COLLISION_REQUIRE_BOTH_CAMERAS=true
COLLISION_MIN_RISK_FOR_ALERT=0.4
COLLISION_ALERT_DURATION=10.0
COLLISION_ALERT_COOLDOWN=12.0
COLLISION_ENABLE_AUDIO=false
COLLISION_ALERT_LOG_DIR=data/alerts

## MDR Patient Email Alerts
# MDR_ALERT_THRESHOLD_SECONDS == minimum contact duration (seconds) before sending alert
# Change this value to adjust alert timing: 240 (4min), 300 (5min), 600 (10min), etc.
MDR_ALERT_THRESHOLD_SECONDS=300
# MDR_SMTP_SERVER == SMTP server address (Gmail example)
MDR_SMTP_SERVER=smtp.gmail.com
# MDR_SMTP_PORT == SMTP port (587 for TLS, 465 for SSL)
MDR_SMTP_PORT=587
# MDR_SMTP_USERNAME == email account username (usually full email address)
MDR_SMTP_USERNAME=your-email@gmail.com
# MDR_SMTP_PASSWORD == email account password or app-specific password
MDR_SMTP_PASSWORD=your-app-password
# MDR_FROM_EMAIL == sender email address (defaults to SMTP_USERNAME if not set)
MDR_FROM_EMAIL=your-email@gmail.com
# MDR_ADMIN_EMAIL == recipient email address for MDR alerts
MDR_ADMIN_EMAIL=admin@hospital.com
