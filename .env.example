# Copy this file to .env and tweak the values as needed.
# Each setting mirrors a CLI option; flags still override the values below.

## Registration CLI equivalents
# FACE_REG_UNMASKED_SAMPLES == --unmasked-samples
FACE_REG_UNMASKED_SAMPLES=20
# FACE_REG_MASKED_SAMPLES == --masked-samples
FACE_REG_MASKED_SAMPLES=12
# FACE_REG_MIN_CONFIDENCE == --min-confidence
FACE_REG_MIN_CONFIDENCE=0.35
# FACE_REG_CAPTURE_DELAY == --capture-delay
FACE_REG_CAPTURE_DELAY=0.45
# FACE_REG_CAMERA_INDEX == --camera-index
FACE_REG_CAMERA_INDEX=0
# FACE_REG_USE_GPU == --use-gpu
FACE_REG_USE_GPU=false
# FACE_REG_VIDEO_PROMPT == --video-prompt/--no-video-prompt (choose videos via dialog)
FACE_REG_VIDEO_PROMPT=false

## Recognition CLI equivalents
# FACE_RECOG_MIN_CONFIDENCE == --min-confidence
FACE_RECOG_MIN_CONFIDENCE=0.35
# FACE_RECOG_THRESHOLD == --threshold
FACE_RECOG_THRESHOLD=0.32
# FACE_RECOG_DET_SIZE == --det-size
FACE_RECOG_DET_SIZE=640
# FACE_RECOG_CAMERA_INDEX == --camera-index
FACE_RECOG_CAMERA_INDEX=0
# FACE_RECOG_USE_GPU == --use-gpu
FACE_RECOG_USE_GPU=false
# FACE_RECOG_VIDEO_PATH == --video-path (leave blank to keep webcam input)
FACE_RECOG_VIDEO_PATH=
# FACE_RECOG_VIDEO_PROMPT == --video-prompt/--no-video-prompt
FACE_RECOG_VIDEO_PROMPT=false
# FACE_RECOG_ENABLE_REID == --enable-reid/--disable-reid
FACE_RECOG_ENABLE_REID=false
# FACE_REID_DET_CONF == --reid-det-conf
FACE_REID_DET_CONF=0.35
# FACE_REID_DETECTOR == --reid-detector (YOLO weights path)
FACE_REID_DETECTOR=yolov8n.pt
# FACE_REID_EMBEDDER_GPU == use GPU for OSNet features (defaults to false)
FACE_REID_EMBEDDER_GPU=false
